# Ignore everything in the directory by default
/*

# 1. Un-ignore the .gitignore itself
!.gitignore

# 2. Window Manager & Desktop Environment
!/hypr/
!/waybar/
!/rofi/
!/wofi/
!/swaync/
!/wlogout/
!/hyprpanel/

# 3. Terminals & Editors
!/kitty/
!/ghostty/
!/nvim/
!/tmux/

# 4. System Monitors & CLI Tools
!/btop/
!/htop/
!/ranger/
!/lazygit/
!/neofetch/

# 5. Utilities
!/waypaper/
!/easyeffects/
!/solaar/
!/redshift/
!/obs-studio/

# 6. (Optional) Ignore specific large files/folders inside the whitelisted ones
/obs-studio/logs/
/obs-studio/profiler_data/
/waybar/waybar_bak/
/waybar/config_bak
/waybar/config copy
